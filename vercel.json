{
  "crons": [
    { "path": "/api/cron/chatbot-analytics", "schedule": "0 2 * * *" },
    { "path": "/api/cron/chatbot-demo-expiry", "schedule": "0 6 * * *" },
    { "path": "/api/cron/chatbot-monthly-reset", "schedule": "0 0 1 * *" },
    { "path": "/api/cron/seo-monthly-dispatch", "schedule": "0 3 1 * *" },
    { "path": "/api/cron/email-campaign-send", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/email-sequence-process", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/email-monthly-reset", "schedule": "0 1 1 * *" },
    { "path": "/api/cron/crm-automation-process", "schedule": "* * * * *" },
    { "path": "/api/cron/crm-task-reminders", "schedule": "0 12 * * *" },
    { "path": "/api/cron/crm-task-archive", "schedule": "0 0 1 * *" },
    { "path": "/api/cron/review-poll", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/review-analytics", "schedule": "0 2 * * *" },
    { "path": "/api/cron/review-attribution", "schedule": "0 8 * * *" },
    { "path": "/api/cron/ad-monthly-report", "schedule": "0 0 1 * *" }
  ],
  "headers": [
    {
      "source": "/chat/:path*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline'; img-src 'self' https://*.vercel-storage.com https://ophidianai.com; connect-src 'self'; style-src 'self' 'unsafe-inline'; frame-ancestors *"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
