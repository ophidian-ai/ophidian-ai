# ============================================================
# Environment Variables -- ophidian-ai (Next.js)
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ------------------------------------------------------------
# Vercel KV (Redis / Upstash)
# ------------------------------------------------------------
KV_URL=redis://<host>:<port>
KV_REST_API_URL=https://<host>.upstash.io
KV_REST_API_TOKEN=<kv-rest-api-token>
KV_REST_API_READ_ONLY_TOKEN=<kv-rest-api-read-only-token>
REDIS_URL=redis://<host>:<port>

# ------------------------------------------------------------
# Resend (transactional email)
# ------------------------------------------------------------
RESEND_API_KEY=re_<your-resend-api-key>

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<your-stripe-publishable-key>

# Stripe Products
STRIPE_PRODUCT_WEB_STARTER=prod_<id>
STRIPE_PRODUCT_WEB_PROFESSIONAL=prod_<id>
STRIPE_PRODUCT_WEB_ECOMMERCE=prod_<id>
STRIPE_PRODUCT_MAINTENANCE_STANDARD=prod_<id>
STRIPE_PRODUCT_MAINTENANCE_ECOMMERCE=prod_<id>
STRIPE_PRODUCT_SEO_CLEANUP_ADVISORY=prod_<id>
STRIPE_PRODUCT_SEO_CLEANUP_DFY=prod_<id>
STRIPE_PRODUCT_SEO_GROWTH_STANDARD=prod_<id>
STRIPE_PRODUCT_SEO_GROWTH_PREMIUM=prod_<id>
STRIPE_PRODUCT_ADDON_PAGE=prod_<id>
STRIPE_PRODUCT_ADDON_BLOG=prod_<id>
STRIPE_PRODUCT_ADDON_BOOKING=prod_<id>
STRIPE_PRODUCT_ADDON_CONTENT=prod_<id>
STRIPE_PRODUCT_ADDON_EMAIL_MARKETING=prod_<id>
STRIPE_PRODUCT_ADDON_LOGO=prod_<id>
STRIPE_PRODUCT_ADDON_ATTRIBUTION_REMOVAL=prod_<id>

# Stripe Prices
STRIPE_PRICE_WEB_STARTER=price_<id>
STRIPE_PRICE_WEB_PROFESSIONAL=price_<id>
STRIPE_PRICE_WEB_ECOMMERCE=price_<id>
STRIPE_PRICE_MAINTENANCE_STANDARD=price_<id>
STRIPE_PRICE_MAINTENANCE_ECOMMERCE=price_<id>
STRIPE_PRICE_SEO_CLEANUP_ADVISORY=price_<id>
STRIPE_PRICE_SEO_CLEANUP_DFY=price_<id>
STRIPE_PRICE_SEO_GROWTH_STANDARD=price_<id>
STRIPE_PRICE_SEO_GROWTH_PREMIUM=price_<id>
STRIPE_PRICE_ADDON_PAGE=price_<id>
STRIPE_PRICE_ADDON_BLOG=price_<id>
STRIPE_PRICE_ADDON_BOOKING=price_<id>
STRIPE_PRICE_ADDON_CONTENT=price_<id>
STRIPE_PRICE_ADDON_EMAIL_MARKETING=price_<id>
STRIPE_PRICE_ADDON_LOGO=price_<id>
STRIPE_PRICE_ADDON_ATTRIBUTION_REMOVAL=price_<id>

# ------------------------------------------------------------
# Google APIs
# ------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>

# Google PageSpeed Insights API key
# Required by: SEO scan engine (speed and mobile analysis modules)
# Get it at: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PSI_API_KEY=<your-google-psi-api-key>

# ------------------------------------------------------------
# Firecrawl (web scraping / research)
# Required by: SEO scan engine (on-page and content analysis modules)
# Get it at: https://www.firecrawl.dev
# ------------------------------------------------------------
FIRECRAWL_API_KEY=fc-<your-firecrawl-api-key>

# ------------------------------------------------------------
# SEO Scan Engine -- Internal Auth
# Required by: Iris / outreach pipeline (bypasses public rate limiting)
# Generate a strong random string, e.g.: openssl rand -hex 32
# ------------------------------------------------------------
SCAN_API_KEY=<your-internal-scan-api-key>

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://ophidianai.com

# ------------------------------------------------------------
# Vercel (injected automatically in Vercel environments)
# ------------------------------------------------------------
# VERCEL_OIDC_TOKEN -- injected by Vercel, do not set manually
